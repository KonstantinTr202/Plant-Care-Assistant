<Window x:Class="PlantCareAssistant.WPF.CareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уход за растением" Height="600" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Информация о растении -->
        <Border Grid.Row="0" BorderBrush="LightGreen" BorderThickness="1" 
                CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#F0FFF0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding PlantName}" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding PlantSpecies}" FontStyle="Italic" Foreground="Gray"/>
                    <TextBlock Margin="0,5,0,0">
                        <Run Text="Последний полив: "/>
                        <Run Text="{Binding LastWateringDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Следующий уход:" FontWeight="Bold"/>
                    <TextBlock Margin="0,5,0,0">
                        <Run Text="Полив: "/>
                        <Run Text="{Binding NextWateringDate, StringFormat={}{0:dd.MM.yyyy}}" 
                             Foreground="DarkRed" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0">
                        <Run Text="Удобрение: "/>
                        <Run Text="{Binding NextFertilizerDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Быстрый уход -->
        <GroupBox Grid.Row="1" Header="Быстрое добавление ухода" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="💧 Полить" Width="120" Height="40" Margin="0,0,10,0"
                            Command="{Binding AddWateringCommand}"/>
                    <Button Content="🌱 Удобрить" Width="120" Height="40" Margin="0,0,10,0"
                            Command="{Binding AddFertilizerCommand}"/>
                    <Button Content="💦 Опрыскать" Width="120" Height="40"
                            Command="{Binding AddSprayingCommand}"/>
                </StackPanel>

                <TextBlock Text="Примечания:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCareNotes" Height="60" TextWrapping="Wrap" 
                         AcceptsReturn="True" Margin="0,0,0,10"/>
            </StackPanel>
        </GroupBox>

        <!-- История ухода -->
        <GroupBox Grid.Row="2" Header="История ухода">
            <DataGrid ItemsSource="{Binding CareRecords}" AutoGenerateColumns="False" 
                      CanUserAddRows="False" Height="200">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="120"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100"/>
                    <DataGridTextColumn Header="Примечания" Binding="{Binding Notes}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>